msgstr "Simpan flipbook terlebih dahulu untuk mendapatkan shortcode dan tautannya."

msgid "Search Flipbooks"
msgstr "Cari Flipbook"

msgid "Select a PDF"
msgstr "Pilih PDF"

msgid "Select logo"
msgstr "Pilih logo"

